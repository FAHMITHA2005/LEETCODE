(select name as results
from MovieRating
join Users USING(user_id)
group by user_id
order by count(*)desc,name asc
limit 1)
union all
(select title as results
from MovieRating
join Movies using(movie_id)
where created_at like '2020-02-%'
group by movie_id
order by AVG(rating)DESC, title  asc
limit 1);
